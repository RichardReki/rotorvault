# Copy to .env (gitignored). Run with: node --env-file=.env ... / tsx --env-file=.env ...
COSTON2_RPC_URL=https://coston2-api.flare.network/ext/C/rpc

# Addresses from the Plan 2 deploy (forge script script/Deploy.s.sol --broadcast)
ROTOR_VAULT=
REGIME_GATE=
APY_ORACLE=
FIRELIGHT_ADAPTER=
UPSHIFT_ADAPTER=

# SAFETY: real on-chain writes (rebalance / submitApy) require BOTH of the below.
# Leave ENABLE_ONCHAIN_WRITE unset/false for dry-run (default).
ENABLE_ONCHAIN_WRITE=
# AGENT_PRIVATE_KEY=0x...   # USER fills only when broadcasting; NEVER commit
